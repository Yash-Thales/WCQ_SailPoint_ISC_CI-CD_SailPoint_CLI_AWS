      "steps": {
        "Manage ServiceNow Ticket": {
          "actionId": "sp:snow",
          "attributes": {
            "action": "create"
          },
          "nextStep": "Wait",
          "type": "action",
          "versionNumber": 1
        },
        "Manage ServiceNow Ticket 1": {
