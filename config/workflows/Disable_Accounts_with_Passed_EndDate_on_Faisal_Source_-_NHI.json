{
  "version": 1,
  "self": {
    "id": "b27ef8de-80c0-42dc-abd4-01ab0f6b1913",
    "name": "Disable Accounts with Passed EndDate on Faisal Source - NHI",
    "type": "WORKFLOW"
  },
  "object": {
    "id": "b27ef8de-80c0-42dc-abd4-01ab0f6b1913",
    "name": "Disable Accounts with Passed EndDate on Faisal Source - NHI",
    "description": "Workflow to disable accounts on Faisal Source - NHI: Delimited File when their EndDate has passed",
    "created": "2026-06-29T02:27:14.751565871Z",
    "modified": "2026-06-29T02:29:11.353018289Z",
    "modifiedBy": {
      "type": "IDENTITY",
      "id": "5416c032c7884ffa818687ccbfe92fc3",
      "name": "faisal.mustafa"
    },
    "definition": {
      "start": "Get Accounts",
      "steps": {
        "End Step - Success": {
          "displayName": "Workflow Complete",
          "type": "success"
        },
        "Get Accounts": {
          "actionId": "sp:get-accounts",
          "attributes": {
            "accountAttribute": "sourceId",
            "getAccountsBy": "accountData",
            "operator": "Equals",
            "value": "faisal-source-nhi-delimited-file-id"
          },
          "displayName": "Get Accounts from Faisal Source",
          "nextStep": "Loop Through Accounts",
          "type": "action",
          "versionNumber": 1
        },
        "Loop Through Accounts": {
          "actionId": "sp:loop:iterator",
          "attributes": {
            "input.$": "$.getAccounts.accounts",
            "loopInput.$": "$.getAccounts",
            "start": "Compare EndDate",
            "steps": {
              "Compare EndDate": {
                "choiceList": [
                  {
                    "comparator": "TimestampLessThan",
                    "nextStep": "Disable Account",
                    "variableA.$": "$.loop.loopInput.attributes.endDate",
                    "variableB.$": "$.trigger.timestamp"
                  }
                ],
                "defaultStep": "End Loop - Success",
                "displayName": "Check if EndDate has passed",
                "type": "choice"
              },
              "Disable Account": {
                "actionId": "sp:manage-account",
                "attributes": {
                  "accountAction": "Disable",
                  "accountIds.$": "$.loop.loopInput.id"
                },
                "displayName": "Disable Account",
                "nextStep": "End Loop - Success",
                "type": "action",
                "versionNumber": 1
              },
              "End Loop - Success": {
                "displayName": "End Loop",
                "type": "success"
              }
            }
          },
          "displayName": "Loop Through Accounts",
          "nextStep": "End Step - Success",
          "type": "action",
          "versionNumber": 1
        }
      }
    },
    "enabled": true,
    "creator": {
      "type": "IDENTITY",
      "id": "5416c032c7884ffa818687ccbfe92fc3",
      "name": "faisal.mustafa"
    },
    "owner": {
      "type": "IDENTITY",
      "id": "5416c032c7884ffa818687ccbfe92fc3",
      "name": "faisal.mustafa"
    },
    "trigger": {
      "type": "SCHEDULED",
      "attributes": {
        "cronString": "0 1 * * *",
        "dailyTimes": [
          "1969-12-31T06:00:00.000Z"
        ],
        "frequency": "daily",
        "id": "idn:cron-schedule",
        "integrationId": null,
        "timeZone": "America/New_York"
      }
    }
  }
}
